---
import BaseLayout from '../layouts/BaseLayout.astro';
import Layout from '../components/Layout.astro';
import Card from '../components/Card.astro';
import FormField from '../components/FormField.astro';
import Button from '../components/Button.astro';

const upperTeeth = Array.from({ length: 16 }, (_, i) => i + 1);
const lowerTeeth = Array.from({ length: 16 }, (_, i) => 32 - i);
const implantSystems = ['Nobel Biocare', 'Straumann', 'Zimmer Biomet', 'BioHorizons', 'Dentsply Sirona', 'Neodent', 'Other'];
const tomorrow = new Date();
tomorrow.setDate(tomorrow.getDate() + 1);
const minDate = tomorrow.toISOString().slice(0, 10);
---

<BaseLayout title="Submit Case | RMDI">
  <Layout>
    <Card>
      <h1 class="text-2xl font-bold text-secondary-900">Submit a Case</h1>
      <p class="mt-2 text-sm text-secondary-700">Step 1 of 2: provide case details and select your review slot.</p>

      <div id="form-alert" class="mt-4 hidden rounded-md border px-4 py-3 text-sm"></div>

      <form id="case-form" class="mt-6 space-y-6">
        <section class="grid gap-4 md:grid-cols-2">
          <FormField id="doctorName" label="Doctor name" required>
            <input id="doctorName" name="doctorName" required minlength="2" class="w-full rounded-md border border-secondary-300 px-3 py-2" />
          </FormField>
          <FormField id="practiceName" label="Practice name" required>
            <input id="practiceName" name="practiceName" required minlength="2" class="w-full rounded-md border border-secondary-300 px-3 py-2" />
          </FormField>
          <FormField id="email" label="Email" required>
            <input id="email" name="email" type="email" required class="w-full rounded-md border border-secondary-300 px-3 py-2" />
          </FormField>
          <FormField id="phone" label="Phone">
            <input id="phone" name="phone" type="tel" class="w-full rounded-md border border-secondary-300 px-3 py-2" />
          </FormField>
        </section>

        <section class="space-y-4">
          <FormField id="toothNumbers" label="Tooth number(s)" required hint="Select all that apply (Universal numbering 1-32)">
            <!-- Upper arch (1-16, right to left from patient perspective) -->
            <p class="text-xs text-secondary-500 mb-1">Upper Arch</p>
            <div class="grid grid-cols-8 gap-1 sm:grid-cols-16 mb-2">
              {upperTeeth.map((tooth) => (
                <label class="flex flex-col items-center rounded border border-secondary-200 px-1 py-1 text-xs hover:border-primary cursor-pointer">
                  <input type="checkbox" name="toothNumbers" value={tooth} class="h-3 w-3" />
                  <span class="mt-0.5">{tooth}</span>
                </label>
              ))}
            </div>
            <!-- Lower arch (32-17, right to left from patient perspective) -->
            <p class="text-xs text-secondary-500 mb-1">Lower Arch</p>
            <div class="grid grid-cols-8 gap-1 sm:grid-cols-16">
              {lowerTeeth.map((tooth) => (
                <label class="flex flex-col items-center rounded border border-secondary-200 px-1 py-1 text-xs hover:border-primary cursor-pointer">
                  <input type="checkbox" name="toothNumbers" value={tooth} class="h-3 w-3" />
                  <span class="mt-0.5">{tooth}</span>
                </label>
              ))}
            </div>
          </FormField>

          <div class="grid gap-4 md:grid-cols-2">
            <FormField id="implantSystem" label="Implant system" required>
              <select id="implantSystem" name="implantSystem" required class="w-full rounded-md border border-secondary-300 px-3 py-2">
                <option value="">Select system</option>
                {implantSystems.map((system) => <option value={system}>{system}</option>)}
              </select>
            </FormField>
            <FormField id="dateNeeded" label="Date needed by" required>
              <input id="dateNeeded" name="dateNeeded" type="date" required min={minDate} class="w-full rounded-md border border-secondary-300 px-3 py-2" />
            </FormField>
          </div>
        </section>

        <section class="space-y-3">
          <h2 class="text-sm font-semibold text-secondary-800">Preferred review date & time <span class="text-red-600">*</span></h2>
          <p class="text-xs text-secondary-500">Select your preferred 15-minute review slot. We'll confirm availability via email.</p>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label for="reviewDate" class="block text-sm font-medium text-secondary-700 mb-1">Date</label>
              <input id="reviewDate" name="reviewDate" type="date" required min={minDate} class="w-full rounded-md border border-secondary-300 px-3 py-2" />
            </div>
            <div>
              <label for="reviewTime" class="block text-sm font-medium text-secondary-700 mb-1">Time (Mountain Time)</label>
              <select id="reviewTime" name="reviewTime" required class="w-full rounded-md border border-secondary-300 px-3 py-2">
                <option value="">Select time</option>
                <option value="08:00">8:00 AM</option>
                <option value="08:15">8:15 AM</option>
                <option value="08:30">8:30 AM</option>
                <option value="08:45">8:45 AM</option>
                <option value="09:00">9:00 AM</option>
                <option value="09:15">9:15 AM</option>
                <option value="09:30">9:30 AM</option>
                <option value="09:45">9:45 AM</option>
                <option value="10:00">10:00 AM</option>
                <option value="10:15">10:15 AM</option>
                <option value="10:30">10:30 AM</option>
                <option value="10:45">10:45 AM</option>
                <option value="11:00">11:00 AM</option>
                <option value="11:15">11:15 AM</option>
                <option value="11:30">11:30 AM</option>
                <option value="11:45">11:45 AM</option>
                <option value="12:00">12:00 PM</option>
                <option value="12:15">12:15 PM</option>
                <option value="12:30">12:30 PM</option>
                <option value="12:45">12:45 PM</option>
                <option value="13:00">1:00 PM</option>
                <option value="13:15">1:15 PM</option>
                <option value="13:30">1:30 PM</option>
                <option value="13:45">1:45 PM</option>
                <option value="14:00">2:00 PM</option>
                <option value="14:15">2:15 PM</option>
                <option value="14:30">2:30 PM</option>
                <option value="14:45">2:45 PM</option>
                <option value="15:00">3:00 PM</option>
                <option value="15:15">3:15 PM</option>
                <option value="15:30">3:30 PM</option>
                <option value="15:45">3:45 PM</option>
                <option value="16:00">4:00 PM</option>
                <option value="16:15">4:15 PM</option>
                <option value="16:30">4:30 PM</option>
                <option value="16:45">4:45 PM</option>
                <option value="17:00">5:00 PM</option>
              </select>
            </div>
          </div>
        </section>

        <section class="space-y-3">
          <h2 class="text-sm font-semibold text-secondary-800">Lab delivery <span class="text-red-600">*</span></h2>

          <label class="block rounded-md border border-secondary-200 p-3 text-sm">
            <input type="radio" name="labDeliveryOption" value="self" checked />
            <span class="ml-2">Send STL back to me for local production</span>
          </label>

          <label class="block rounded-md border border-secondary-200 p-3 text-sm">
            <input type="radio" name="labDeliveryOption" value="partner" />
            <span class="ml-2">Send to partner lab</span>
            <select id="partnerLab" name="partnerLab" class="mt-3 hidden w-full rounded-md border border-secondary-300 px-3 py-2">
              <option value="">Choose partner lab</option>
              <option value="newcraft">Newcraft Dental Arts</option>
              <option value="bioaesthetic">Bio Aesthetic Dental Studio</option>
            </select>
          </label>

          <label class="block rounded-md border border-secondary-200 p-3 text-sm">
            <input type="radio" name="labDeliveryOption" value="custom" />
            <span class="ml-2">Send to my lab</span>
            <div id="custom-lab-fields" class="mt-3 hidden grid gap-3 md:grid-cols-2">
              <input name="labName" placeholder="Lab name" class="rounded-md border border-secondary-300 px-3 py-2" />
              <input name="labEmail" type="email" placeholder="Lab email" class="rounded-md border border-secondary-300 px-3 py-2" />
            </div>
          </label>
        </section>

        <FormField id="notes" label="Notes" hint="Optional (max 1000 characters)">
          <textarea id="notes" name="notes" maxlength="1000" rows="4" class="w-full rounded-md border border-secondary-300 px-3 py-2"></textarea>
        </FormField>

        <label class="flex items-start gap-2 rounded-md border border-secondary-200 p-3 text-sm">
          <input id="disclaimerConfirmed" name="disclaimerConfirmed" type="checkbox" required class="mt-0.5 h-4 w-4" />
          <span>I confirm these files have been de-identified and contain no patient name, date of birth, or other identifying information.</span>
        </label>

        <Button type="submit" class="w-full sm:w-auto">Submit Case</Button>
      </form>
    </Card>
  </Layout>
</BaseLayout>

<script>
  const form = document.getElementById('case-form');
  const alertBox = document.getElementById('form-alert');
  const partnerLabSelect = document.getElementById('partnerLab');
  const customLabFields = document.getElementById('custom-lab-fields');

  const showAlert = (type, message) => {
    alertBox.classList.remove('hidden', 'border-red-200', 'bg-red-50', 'text-red-700', 'border-green-200', 'bg-green-50', 'text-green-700');
    if (type === 'error') {
      alertBox.classList.add('border-red-200', 'bg-red-50', 'text-red-700');
    } else {
      alertBox.classList.add('border-green-200', 'bg-green-50', 'text-green-700');
    }
    alertBox.textContent = message;
  };

  document.querySelectorAll('input[name="labDeliveryOption"]').forEach((radio) => {
    radio.addEventListener('change', () => {
      const value = document.querySelector('input[name="labDeliveryOption"]:checked')?.value;
      partnerLabSelect.classList.toggle('hidden', value !== 'partner');
      customLabFields.classList.toggle('hidden', value !== 'custom');
    });
  });

  form.addEventListener('submit', async (event) => {
    event.preventDefault();

    const selectedTeeth = Array.from(document.querySelectorAll('input[name="toothNumbers"]:checked')).map((el) => Number(el.value));
    const labDeliveryOption = document.querySelector('input[name="labDeliveryOption"]:checked')?.value;

    // Combine date and time into ISO datetime
    const reviewDate = form.reviewDate.value;
    const reviewTime = form.reviewTime.value;
    let reviewDatetime = '';
    if (reviewDate && reviewTime) {
      reviewDatetime = `${reviewDate}T${reviewTime}:00`;
    }

    const payload = {
      doctorName: form.doctorName.value,
      practiceName: form.practiceName.value,
      email: form.email.value,
      phone: form.phone.value,
      toothNumbers: selectedTeeth,
      implantSystem: form.implantSystem.value,
      dateNeeded: form.dateNeeded.value,
      reviewDatetime,
      labDeliveryOption,
      partnerLab: form.partnerLab?.value,
      labName: form.labName?.value,
      labEmail: form.labEmail?.value,
      notes: form.notes.value,
      disclaimerConfirmed: form.disclaimerConfirmed.checked,
    };

    try {
      const response = await fetch('/api/submit-case', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await response.json();

      if (!response.ok) {
        const message = Array.isArray(data.errors) ? data.errors.join(' ') : data.error || 'Submission failed.';
        showAlert('error', message);
        return;
      }

      showAlert('success', `Case submitted successfully. Case ID: ${data.caseId}`);
      setTimeout(() => {
        window.location.href = `/upload/${data.uploadToken}`;
      }, 900);
    } catch (error) {
      showAlert('error', error instanceof Error ? error.message : 'Submission failed.');
    }
  });
</script>
