---
import BaseLayout from '../layouts/BaseLayout.astro';
import Layout from '../components/Layout.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';

const pricing = [
  { tier: 'Standard Planning', fee: '$100/case', nobel: '$75/case', turnaround: '48-72 hours' },
  { tier: 'Volume Planning (10+/month)', fee: '$85/case', nobel: '$60/case', turnaround: '48-72 hours' },
  { tier: 'Expedited Add-On', fee: '+$50', nobel: '+$40', turnaround: '24 hours' },
];
---

<BaseLayout title="RMDI Services">
  <Layout>
    <div class="space-y-6">
      <Card class="space-y-3">
        <h1 class="text-3xl font-bold text-secondary-900">Surgical Guide Planning Services</h1>
        <p class="text-secondary-700">Planning support for Nobel, Straumann, Zimmer, BioHorizons, and all major implant systems.</p>
      </Card>

      <Card>
        <h2 class="text-xl font-semibold text-secondary-900">Pricing</h2>
        <div class="mt-4 overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead>
              <tr class="border-b border-secondary-200 text-left text-secondary-600">
                <th class="px-3 py-2 font-semibold">Tier</th>
                <th class="px-3 py-2 font-semibold">Standard</th>
                <th class="px-3 py-2 font-semibold">Nobel Discount</th>
                <th class="px-3 py-2 font-semibold">Turnaround</th>
              </tr>
            </thead>
            <tbody>
              {pricing.map((row) => (
                <tr class="border-b border-secondary-100">
                  <td class="px-3 py-2 font-medium text-secondary-900">{row.tier}</td>
                  <td class="px-3 py-2">{row.fee}</td>
                  <td class="px-3 py-2">{row.nobel}</td>
                  <td class="px-3 py-2">{row.turnaround}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </Card>

      <section class="grid gap-6 md:grid-cols-2">
        <Card class="space-y-3">
          <h2 class="text-xl font-semibold text-secondary-900">Process</h2>
          <ol class="list-inside list-decimal space-y-2 text-secondary-700">
            <li>Submit case details and pick a 15-minute review slot.</li>
            <li>Upload de-identified CBCT and STL files.</li>
            <li>Receive planning output and consultation support.</li>
          </ol>
        </Card>
        <Card class="space-y-3">
          <h2 class="text-xl font-semibold text-secondary-900">FAQ</h2>
          <p class="text-sm text-secondary-700"><strong>What files are required?</strong> CBCT (DICOM) and STL scan files.</p>
          <p class="text-sm text-secondary-700"><strong>How fast is turnaround?</strong> 48-72 hours standard, 24 hours expedited.</p>
          <p class="text-sm text-secondary-700"><strong>Do you support remote providers?</strong> Yes, nationwide remote support is available.</p>
        </Card>
      </section>

      <Card class="flex flex-wrap items-center justify-between gap-4">
        <p class="font-semibold text-secondary-900">Ready to start?</p>
        <Button href="/submit-case">Submit a Case</Button>
      </Card>
    </div>
  </Layout>
</BaseLayout>
