---
const links = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/submit-case', label: 'Submit Case' },
];
---

<header class="border-b border-secondary-200 bg-white">
  <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
    <a href="/" class="text-lg font-bold text-secondary-900">Rocky Mountain Dental Implants</a>
    <nav class="flex items-center gap-5 text-sm font-semibold">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            'transition hover:text-primary',
            Astro.url.pathname === link.href ? 'text-primary' : 'text-secondary-700',
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>
