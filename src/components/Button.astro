---
interface Props {
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'secondary';
  href?: string;
  class?: string;
}

const { type = 'button', variant = 'primary', href, class: className = '' } = Astro.props;
const base = 'inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-semibold transition focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-70';
const style = variant === 'secondary'
  ? 'border border-secondary-300 bg-white text-secondary-800 hover:bg-secondary-100'
  : 'bg-primary text-white hover:bg-blue-700';
---

{href ? (
  <a href={href} class={`${base} ${style} ${className}`}>
    <slot />
  </a>
) : (
  <button type={type} class={`${base} ${style} ${className}`}>
    <slot />
  </button>
)}
