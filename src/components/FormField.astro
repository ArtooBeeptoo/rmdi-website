---
interface Props {
  id: string;
  label: string;
  required?: boolean;
  hint?: string;
}

const { id, label, required = false, hint } = Astro.props;
---

<div class="space-y-1.5">
  <label for={id} class="block text-sm font-semibold text-secondary-800">
    {label}
    {required && <span class="ml-1 text-red-600">*</span>}
  </label>
  {hint && <p class="text-xs text-secondary-500">{hint}</p>}
  <slot />
</div>
